{
  "name": "arki",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "token:google": "node scripts/get-google-token.mjs",
    "wilma:probe": "node scripts/wilma-probe.mjs",
    "cron:refresh": "node scripts/cron-refresh.mjs",
    "cron:fetch": "node --env-file-if-exists=.env --import tsx scripts/cron-fetch.ts"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.6.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "google-auth-library": "^9.14.0"
  },
  "engines": {
    "node": "22.x"
  }
}
