# --- Google Calendar ---
# Option A (recommended for personal calendars): OAuth refresh token
# 1. Create an OAuth 2.0 Client (type: Desktop) in Google Cloud Console.
# 2. Run a one-time flow (e.g. https://developers.google.com/oauthplayground)
#    with scope https://www.googleapis.com/auth/calendar.readonly to obtain a refresh token.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Option B: Service account (Workspace) — paste the full JSON on a single line.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Comma-separated calendar IDs. "primary" is the signed-in user's main calendar.
GOOGLE_CALENDAR_IDS=primary

# --- Wilma ---
# Unofficial, per-school variations exist. After setting these, run
# `pnpm wilma:probe` to verify the endpoints your school uses.
WILMA_BASE_URL=https://helsinki.inschool.fi
WILMA_USERNAME=
WILMA_PASSWORD=

# --- Database (SQLite) ---
# When set, the app reads events from a local SQLite file instead of
# live-fetching on every page load. A cron (systemd timer) populates it.
# Leave unset to keep the old live-fetch behaviour (fine for local dev).
SQLITE_PATH=./data/arki.db

# --- Auth ---
# Static site password. Set to whatever you want users to type.
AUTH_PASSWORD=

# --- Cron ---
# Shared secret required by /api/cron/refresh. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
